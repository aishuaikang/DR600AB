# Backend runtime environment.
# The Go service reads these from the process environment. It does not load this file automatically.

# HTTP listen address.
API_ADDR=:18080

# Default UI/API locale.
API_DEFAULT_LOCALE=zh-CN

# Persistent settings JSON path.
API_SETTINGS_PATH=./backend/data/detection-settings.json

# Serial defaults shared by detection and GPS sessions.
API_DEFAULT_BAUD=115200
API_DEFAULT_DATA_BITS=8
API_DEFAULT_STOP_BITS=1
API_DEFAULT_PARITY=none
API_DEFAULT_READ_TIMEOUT_MS=1000

# Auto reconnect timing.
API_RECONNECT_INITIAL_DELAY_MS=1000
API_RECONNECT_MAX_DELAY_MS=15000

# In-memory list limits and SSE buffer size.
API_MAX_DETECTION_RECORDS=500
API_MAX_PARSED_MESSAGES=500
API_EVENT_BUFFER_SIZE=64

# Developer login.
# Replace this in production.
API_DEVELOPER_TOTP_SECRET=VUPSQXCB6U5WPBKOKTQ6WICVWHAUX2S4
API_DEVELOPER_SESSION_TTL_SECONDS=600

# Comma-separated CORS origins for local frontend development.
API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# O3+/O4 encrypted DID MQTT decrypt.
# Decrypt is disabled by default. Set enabled=true and configure broker/username to use it.
API_O3_DECRYPT_ENABLED=false
API_O3_DECRYPT_BROKER=
API_O3_DECRYPT_PORT=1883
API_O3_DECRYPT_USERNAME=
API_O3_DECRYPT_PASSWORD=
API_O3_DECRYPT_TIMEOUT_MS=10000
API_O3_DECRYPT_CONNECT_TIMEOUT_MS=10000
